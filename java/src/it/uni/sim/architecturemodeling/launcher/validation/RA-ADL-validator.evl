import "validation-scripts.eol";

context weaving!RA_ADL_Relation {

    constraint relationType {

        check: self.checkRelation()

        message: "constraint=relationType | component: " + self.component.name +
                 " does not respect the RA rules. Reasons: " +
                 self.relationViolations().toJoinedString(" || ")
    }

}

context weaving!Implementation_model {

    constraint MandatoryComponents {

        check: self.checkMandatoryComponents()

        message: "constraint=MandatoryComponents | Not all the mandatory components in the RA are used. Missing: " +
                 self.missingMandatoryComponents().collect(x | x.name).toJoinedString(", ")
    }

}
